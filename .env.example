# --- Telegram ---
BOT_TOKEN=

# --- Postgres ---
# Пароль суперпользователя БД. Задай ДЛИННЫЙ случайный (НЕ "postgres").
# Сгенерировать: openssl rand -hex 24
# Используется и контейнером postgres, и в DATABASE_URL для бота (docker-compose).
POSTGRES_PASSWORD=

# DATABASE_URL нужен для запуска БЕЗ docker (локально).
# В docker-compose он переопределяется и хост = postgres, пароль = POSTGRES_PASSWORD.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/thinker_bot

# --- LLM (OpenAI-совместимый API) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
